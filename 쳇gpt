<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<title>SkyPin v5 UX FINAL</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/suncalc@1.9.0/suncalc.js"></script>

<style>
html,body{margin:0;height:100%;font-family:-apple-system;}
#map{height:100vh;}

#ui{position:fixed;width:100%;height:100%;pointer-events:none;z-index:9999;}
#menuBtn,#menu,#panel{pointer-events:auto;}

#menuBtn{
 position:absolute;bottom:80px;right:15px;
 width:60px;height:60px;border-radius:50%;
 background:#ff3b30;color:#fff;border:none;font-size:22px;
}

#menu{
 position:absolute;bottom:150px;right:15px;
 display:none;flex-direction:column;gap:6px;
}
#menu button{
 padding:10px;background:#333;color:#fff;border:none;border-radius:8px;
}

#panel{
 position:absolute;top:0;right:0;width:320px;height:100%;
 background:#fff;transform:translateX(100%);
 transition:.3s;overflow:auto;
}
#panel.show{transform:translateX(0);}

#panelHeader{
 padding:12px;background:#111;color:#fff;
 display:flex;justify-content:space-between;
}

#panelContent{padding:12px;}

.card{background:#f5f5f5;padding:10px;margin-bottom:8px;border-radius:8px;cursor:pointer;}
.card img{width:100%;border-radius:6px;margin-top:5px;}

input,select{width:100%;padding:8px;margin-bottom:5px;}
button.add{width:100%;padding:8px;background:#007aff;color:#fff;border:none;border-radius:6px;}
.card button{margin-top:5px;background:#ff3b30;color:#fff;border:none;padding:5px;border-radius:5px;}

.sunBox{background:#ffe8a3;padding:8px;border-radius:8px;margin-bottom:8px;}
</style>
</head>

<body>

<div id="map"></div>

<div id="ui">
<button id="menuBtn">☰</button>

<div id="menu">
  <button id="btnExplore">📍 탐색</button>
  <button id="btnShots">📸 촬영지</button>
  <button id="btnSun">🌅 태양</button>
</div>

<div id="panel">
  <div id="panelHeader">
    <span id="panelTitle">SkyPin</span>
    <button id="closeBtn">닫기</button>
  </div>

  <div id="panelContent">

    <!-- 🌅 태양 -->
    <div id="sunUI" style="display:none;">
      <div class="sunBox">
        <input type="date" id="sunDate">
        <div id="sunInfo"></div>
      </div>
    </div>

    <!-- 탐색 -->
    <div id="exploreUI">
      <input id="search" placeholder="검색">
      <select id="filter">
        <option value="all">전체</option>
        <option value="서울">서울</option>
        <option value="부산">부산</option>
      </select>

      <button class="add" id="btnGPS">📍 내 위치</button>

      <div>
        <input id="poiName" placeholder="명소 이름">
        <input id="poiRegion" placeholder="지역">
        <button class="add" id="addPOI">명소 추가</button>
      </div>
    </div>

    <!-- 촬영지 -->
    <div id="shotUI" style="display:none;">
      <input id="shotName" placeholder="촬영지">
      <textarea id="shotMemo" placeholder="메모"></textarea>
      <input type="file" id="photo">
      <button class="add" id="saveShot">저장</button>
    </div>

    <div id="list"></div>

  </div>
</div>
</div>

<script>
window.onload=function(){

/* DOM */
const menuBtn=menu=document.getElementById("menuBtn");
const panel=document.getElementById("panel");
const menuBox=document.getElementById("menu");

const btnExplore=document.getElementById("btnExplore");
const btnShots=document.getElementById("btnShots");
const btnSun=document.getElementById("btnSun");

const exploreUI=document.getElementById("exploreUI");
const shotUI=document.getElementById("shotUI");
const sunUI=document.getElementById("sunUI");

const listEl=document.getElementById("list");

const search=document.getElementById("search");
const filter=document.getElementById("filter");

const sunDate=document.getElementById("sunDate");
const sunInfo=document.getElementById("sunInfo");

const poiName=document.getElementById("poiName");
const poiRegion=document.getElementById("poiRegion");

const shotName=document.getElementById("shotName");
const shotMemo=document.getElementById("shotMemo");
const photo=document.getElementById("photo");

/* MAP */
const map=L.map("map").setView([37.56,126.97],10);
L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);

let markers=L.layerGroup().addTo(map);
let selected=null;
let myPos=null;

/* DATA */
let defaultPOI=[
 {name:"남산타워",lat:37.5512,lng:126.9882,region:"서울"},
 {name:"해운대",lat:35.1587,lng:129.1604,region:"부산"}
];

let userPOI=JSON.parse(localStorage.getItem("userPOI")||"[]");
let shots=JSON.parse(localStorage.getItem("shots")||"[]");

function save(){
 localStorage.setItem("userPOI",JSON.stringify(userPOI));
 localStorage.setItem("shots",JSON.stringify(shots));
}

/* 이미지 리사이즈 */
function resizeImage(file){
 return new Promise(res=>{
  const img=new Image();
  const reader=new FileReader();
  reader.onload=e=>img.src=e.target.result;
  img.onload=()=>{
   const canvas=document.createElement("canvas");
   const max=400;
   let w=img.width,h=img.height;
   if(w>max){h*=max/w;w=max;}
   canvas.width=w;canvas.height=h;
   canvas.getContext("2d").drawImage(img,0,0,w,h);
   res(canvas.toDataURL("image/jpeg",0.7));
  };
  reader.readAsDataURL(file);
 });
}

/* 메뉴 */
menuBtn.onclick=(e)=>{
 e.stopPropagation();
 menuBox.style.display=(menuBox.style.display==="flex")?"none":"flex";
};

/* 지도 클릭 */
map.on("click",e=>selected=e.latlng);

/* 렌더 */
function render(list){
 listEl.innerHTML="";
 markers.clearLayers();

 list.forEach((p,i)=>{
  const div=document.createElement("div");
  div.className="card";
  div.innerHTML=`<b>${p.name}</b><br>${p.region||""}`;

  if(p.photo){
    const img=document.createElement("img");
    img.src=p.photo;
    div.appendChild(img);
  }

  div.onclick=()=>{
    map.setView([p.lat,p.lng],15);
    markers.clearLayers();
    L.marker([p.lat,p.lng]).addTo(markers);
  };

  listEl.appendChild(div);
 });
}

/* 탐색 */
btnExplore.onclick=()=>{
 panel.classList.add("show");
 exploreUI.style.display="block";
 shotUI.style.display="none";
 sunUI.style.display="none";

 render([...defaultPOI,...userPOI]);
};

/* 촬영지 */
btnShots.onclick=()=>{
 panel.classList.add("show");
 exploreUI.style.display="none";
 shotUI.style.display="block";
 sunUI.style.display="none";

 render(shots);
};

/* GPS */
btnGPS.onclick=()=>{
 navigator.geolocation.getCurrentPosition(pos=>{
  myPos={lat:pos.coords.latitude,lng:pos.coords.longitude};
  map.setView([myPos.lat,myPos.lng],15);
  L.marker([myPos.lat,myPos.lng]).addTo(markers);
 });
};

/* 태양 */
btnSun.onclick=()=>{
 panel.classList.add("show");
 exploreUI.style.display="none";
 shotUI.style.display="none";
 sunUI.style.display="block";

 sunDate.value=new Date().toISOString().split("T")[0];

 drawSun();
};

function drawSun(){
 if(!myPos) return alert("내 위치 먼저");

 const date=new Date(sunDate.value);
 const times=SunCalc.getTimes(date,myPos.lat,myPos.lng);

 const sunrise=times.sunrise;
 const sunset=times.sunset;

 const riseAz=SunCalc.getPosition(sunrise,myPos.lat,myPos.lng).azimuth*180/Math.PI+180;
 const setAz=SunCalc.getPosition(sunset,myPos.lat,myPos.lng).azimuth*180/Math.PI+180;

 sunInfo.innerHTML=`
 🌅 일출: ${sunrise.toLocaleTimeString()}<br>
 🌇 일몰: ${sunset.toLocaleTimeString()}
 `;

 markers.clearLayers();
 L.marker([myPos.lat,myPos.lng]).addTo(markers);

 drawLine(riseAz,"orange");
 drawLine(setAz,"purple");
}

function drawLine(angle,color){
 const dist=0.2;
 const lat2=myPos.lat+dist*Math.cos(angle*Math.PI/180);
 const lng2=myPos.lng+dist*Math.sin(angle*Math.PI/180);

 L.polyline([[myPos.lat,myPos.lng],[lat2,lng2]],{color}).addTo(markers);
}

/* 추가 */
addPOI.onclick=()=>{
 if(!selected) return alert("지도 클릭");
 userPOI.push({name:poiName.value,region:poiRegion.value,lat:selected.lat,lng:selected.lng});
 save();
};

/* 촬영지 저장 */
saveShot.onclick=async()=>{
 if(!selected) return alert("지도 클릭");

 let img="";
 if(photo.files[0]) img=await resizeImage(photo.files[0]);

 shots.push({
  name:shotName.value,
  memo:shotMemo.value,
  lat:selected.lat,
  lng:selected.lng,
  photo:img
 });

 save();
};

/* 날짜 변경 */
sunDate.onchange=drawSun;

};
</script>

</body>
</html>
